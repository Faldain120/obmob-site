{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    { "source": "/(.*)", "has": [{ "type": "host", "value": "obmockoralboards.com" }], "destination": "https://obmob.ai/$1", "permanent": true },
    { "source": "/(.*)", "has": [{ "type": "host", "value": "www.obmockoralboards.com" }], "destination": "https://obmob.ai/$1", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    }
  ]
}
